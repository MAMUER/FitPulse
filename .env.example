#  NEVER commit real .env to Git!
#     Use GitHub Secrets for CI/CD values.

# ============================================
# Environment & Logging (optional)
# ============================================
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=fitness_admin
POSTGRES_PASSWORD=example
POSTGRES_DB=fitness
DB_SSLMODE=disable

# ------------------------------------------
# Database Connection (derived from POSTGRES_*)
# ------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgres://fitness_admin:example@postgres:5432/fitness?sslmode=disable

# ============================================
# Redis
# ============================================
REDIS_ADDR=redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=example
REDIS_DB=0

# ============================================
# RabbitMQ
# ============================================
RABBITMQ_DEFAULT_USER=rabbit_admin
RABBITMQ_DEFAULT_PASS=example
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672/

# ============================================
# JWT
# ============================================
# Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=example-jwt-secret-for-development-only

# ============================================
# SMTP (email verification)
# ============================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=example@example.com
SMTP_PASSWORD=example
SMTP_FROM=example@example.com
SMTP_TLS=true
BASE_URL=https://localhost:8443
EMAIL_DAILY_LIMIT=100
EMAIL_SKIP_DOMAINS=example.com

# ============================================
# Service Ports
# ============================================
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
USER_SERVICE_PORT=50051
BIOMETRIC_SERVICE_PORT=50052
TRAINING_SERVICE_PORT=50053
GATEWAY_PORT=8080
CLASSIFIER_PORT=8001
ML_GENERATOR_PORT=8002
NGINX_HTTPS_PORT=8443
DEVICE_CONNECTOR_PORT=8082

# ============================================
# Service Addresses (Docker internal)
# ============================================
USER_SERVICE_ADDR=user-service:50051
BIOMETRIC_SERVICE_ADDR=biometric-service:50052
TRAINING_SERVICE_ADDR=training-service:50053
DEVICE_CONNECTOR_URL=http://device-connector:8082

# ============================================
# ML Services
# ============================================
CLASSIFIER_URL=http://classifier:8001
ML_GENERATOR_URL=http://ml-generator:8002

# ============================================
# ML Async Mode
# ============================================
ML_ASYNC=true

# ============================================
# Admin Seed (for seed-admin scripts)
# ============================================
SEED_ADMIN_EMAIL=admin@fitpulse.local
SEED_ADMIN_PASSWORD=example

# ============================================
# Test Overrides (optional)
# ============================================
TEST_PASSWORD=example
