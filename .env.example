# FitPulse — Environment Configuration Template
# Copy to .env and fill in values:  cp .env.example .env
#
# ⚠️  NEVER commit real .env to Git!
#     Use GitHub Secrets for CI/CD values.
#
# GitHub Secrets required (add in Settings → Secrets):
#   POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
#   JWT_SECRET
#   REDIS_PASSWORD
#   RABBITMQ_USER, RABBITMQ_PASS, RABBITMQ_URL
#   SMTP_USER, SMTP_PASSWORD
#   DOCKER_USERNAME, DOCKER_PASSWORD, GHCR_TOKEN
#   SSH_PRIVATE_KEY, VPS_HOST, VPS_USER
#   KUBECONFIG
#   SLACK_WEBHOOK_URL, PAGERDUTY_SERVICE_KEY
#   ELASTIC_PASSWORD

# ============================================
# Environment & Observability
# ============================================
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key

# ============================================
# ELK Stack Configuration
# ============================================
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
LOGSTASH_PORT=5044
ELASTIC_PASSWORD=<change-me>

# ============================================
# Prometheus & Monitoring
# ============================================
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=<change-me>
NODE_EXPORTER_PORT=9100

# === Database ===
POSTGRES_USER=fitness_admin
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=fitness
DB_HOST=postgres
DB_PORT=5432
DB_USER=fitness_admin
DB_PASSWORD=<change-me>
DB_NAME=fitness
DB_SSLMODE=disable

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<change-me>
REDIS_DB=0

# === RabbitMQ ===
RABBITMQ_DEFAULT_USER=rabbit_admin
RABBITMQ_DEFAULT_PASS=<change-me>
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672/

# === JWT ===
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=<generate-a-random-secret-here>

# === SMTP (email verification) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=<your-email@yandex.ru>
SMTP_PASSWORD=<app-password-from-yandex>
SMTP_FROM=<your-email@yandex.ru>
SMTP_TLS=true
BASE_URL=https://localhost:8443
EMAIL_DAILY_LIMIT=100
EMAIL_SKIP_DOMAINS=example.com

# === Service Ports ===
USER_SERVICE_PORT=50051
BIOMETRIC_SERVICE_PORT=50052
TRAINING_SERVICE_PORT=50053
GATEWAY_PORT=8080
ML_CLASSIFIER_PORT=8001
ML_GENERATOR_PORT=8002
NGINX_HTTPS_PORT=8443

# === Service Addresses (Docker internal) ===
USER_SERVICE_ADDR=user-service:50051
BIOMETRIC_SERVICE_ADDR=biometric-service:50052
TRAINING_SERVICE_ADDR=training-service:50053

# === ML Services ===
ML_CLASSIFIER_URL=http://ml-classifier:8001
ML_GENERATOR_URL=http://ml-generator:8002
DEVICE_CONNECTOR_URL=http://device-connector:8082

# === ML Async Mode ===
ML_ASYNC=true

# === Admin Seed (for seed-admin.bat) ===
SEED_ADMIN_EMAIL=admin@fitpulse.local
SEED_ADMIN_PASSWORD=<generate-a-secure-password>

# === Test Overrides ===
TEST_PASSWORD=<same-as-seed-or-separate>

cd C:\Users\User\Downloads\Project
scripts/stop-local.bat
scripts/api-test.py
scripts/load-test.py
make check
make proto
scripts/run-local.bat
scripts/setup-and-run.bat
docker system prune -a   # Удалит все неиспользуемые образы, контейнеры, сети и кэш сборки
docker volume prune      # Удалит неиспользуемые тома (осторожно, если нужны данные)